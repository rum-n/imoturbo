{
  "manifest_version": 3,
  "name": "Imoturbo",
  "version": "0.1.0",
  "description": "Покупателска интелигентност за български апартаментни обяви на imot.bg.",
  "icons": {
    "16": "public/icons/icon-16.svg",
    "48": "public/icons/icon-48.svg",
    "128": "public/icons/icon-128.svg"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:8787/*",
    "https://*.imot.bg/*",
    "http://*.imot.bg/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.imot.bg/*", "http://*.imot.bg/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Imoturbo",
    "default_icon": {
      "16": "public/icons/icon-16.svg",
      "48": "public/icons/icon-48.svg",
      "128": "public/icons/icon-128.svg"
    }
  }
}
